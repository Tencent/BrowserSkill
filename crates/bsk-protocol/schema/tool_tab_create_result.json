{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TabCreateResult",
  "type": "object",
  "required": [
    "tab_id",
    "window_id"
  ],
  "properties": {
    "tab_id": {
      "type": "integer",
      "format": "int64"
    },
    "url": {
      "description": "Best-effort URL of the newly created tab. May be empty if Chrome has not yet committed the navigation (e.g. pending load).",
      "default": "",
      "type": "string"
    },
    "window_id": {
      "type": "integer",
      "format": "int64"
    }
  }
}
